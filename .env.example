# Пример файла .env — скопируйте в .env и впишите свои значения.
# Настоящий .env НЕ коммитится и НЕ попадает в Docker-образ (см. .gitignore/.dockerignore).
# На хостинге эти значения задаются через "секреты" (fly secrets set ...), а не файлом.

TELEGRAM_BOT_TOKEN=сюда_токен_бота_от_BotFather
GROQ_API_KEY=сюда_ключ_Groq
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=llama-3.2-11b-vision-preview

ADMIN_USERNAME=admin
ADMIN_PASSWORD=придумайте_надёжный_пароль
ADMIN_PORT=8000
